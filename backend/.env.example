JWT_SECRET=change_me_dev_only
JWT_EXPIRES_MIN=43200

# По умолчанию БД: <корень_репозитория>/database/hhunter.db (см. backend/config.py).
# Раскомментируйте только если нужен свой путь:
# DB_URL=sqlite:///C:/path/to/hhunter.db

FRONTEND_ORIGIN=http://localhost:5173
# CORS: дополнительные origin через запятую; chrome-extension разрешён regex по умолчанию (см. backend/config.py).
# CORS_EXTRA_ORIGINS=
# CORS_ALLOW_CHROME_EXTENSION_REGEX=true
# CORS_CHROME_EXTENSION_IDS=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa,bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb

# Логи (logs/): retention и ротация.
# LOG_DEBUG=0   -> не писать самые подробные диагностические записи (превью резюме/сырой ответ модели)
# LOG_RETENTION_DAYS=7   -> удалять файлы логов старше N дней (по mtime)
# LOG_MAX_MB=10          -> ротация файла при превышении размера (в мегабайтах)
# LOG_DEBUG=0
# LOG_RETENTION_DAYS=7
# LOG_MAX_MB=10

# Опционально: имя модели Gemini (по умолчанию см. backend/config.py)
# GEMINI_MODEL=gemini-2.5-flash

# User-Agent для API hh.ru (в требованиях API должен быть контакт разработчика / приложения).
# HH_API_USER_AGENT=HHunter/1.0 (you@example.com)

# Шифрование Groq API ключа в БД (Fernet base64 key).
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# GROQ_KEY_FERNET_SECRET=
